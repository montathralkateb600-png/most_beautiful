# الإصدار 13 لضمان أعلى توافق مع مكتبات فلاتر الحديثة
platform :ios, '13.0'

# إعدادات الـ CocoaPods للبناء المستقر
install! 'cocoapods', :deterministic_uuids => false

# هذا السطر يخبر Xcode بمكان مكتبات فلاتر (مهم جداً)
target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  # هذه هي الطريقة الصحيحة في فلاتر لربط كل المكتبات (بما فيها Firestore) تلقائياً
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # إعدادات لضمان استقرار البناء وتوحيد الهوية
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'] = 'com.mostbeautiful.app'
      
      # سطر إضافي لحل مشكلة التوافق مع Xcode الحديث في بيئة الـ CI
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'NO'
    end
  end
end